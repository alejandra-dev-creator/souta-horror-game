  m_Name: 
  m_EditorClassIdentifier: 
  textoPuntuacion: {fileID: 1832994052}
  puntajeUmbralParaPregunta: 60
  listaDePreguntas:
  - preguntaTexto: "\"\xBFConsumir alimentos procesados en exceso ayuda a tener m\xE1s
      energ\xEDa para escapar de un villano?\""
    respuestaCorrectaEsSi: 0
    retroalimentacionCorrecta: "Los alimentos procesados pueden dar energ\xEDa r\xE1pida,
      pero son malos para la salud a largo plazo. Necesitas energ\xEDa real para
      escapar."
    retroalimentacionIncorrecta: "Los alimentos procesados te dar\xE1n un baj\xF3n
      de energ\xEDa. Para escapar, necesitas comida nutritiva que te d\xE9 energ\xEDa
      sostenida."
  - preguntaTexto: "\"\xBFLas bayas rojas brillantes son siempre seguras para comer?\""
    respuestaCorrectaEsSi: 0
    retroalimentacionCorrecta: "\xA1Exacto! El color brillante a menudo indica veneno
      en la naturaleza. Muchas bayas rojas son t\xF3xicas y no deben consumirse."
    retroalimentacionIncorrecta: "Incorrecto. Un color brillante puede ser una advertencia
      de que una baya es venenosa. Nunca comas bayas silvestres sin identificaci\xF3n
      segura."
  ultimaRetroalimentacionIncorrecta: 
